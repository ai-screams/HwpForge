{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.ai-screams/hwpforge",
  "description": "AI-native Korean HWP/HWPX document generation, inspection, and editing tools",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@hwpforge/mcp",
      "version": "0.1.6",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "runtimeArguments": [
        {
          "type": "positional",
          "value": "-y",
          "description": "Auto-confirm npx install prompt"
        }
      ]
    }
  ]
}
