{
  "lineWidth": 120,
  "markdown": {
    "lineWidth": 120,
    "textWrap": "maintain"
  },
  "toml": {},
  "json": {
    "indentWidth": 2
  },
  "includes": [
    "**/*.md",
    "**/*.toml",
    "**/*.json"
  ],
  "excludes": [
    "**/target/**",
    "**/node_modules/**",
    "**/.git/**",
    "**/.docs/**",
    "**/.omc/**",
    "**/temp/**",
    "**/*.hwpx",
    "**/CHANGELOG.md"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.20.0.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/json-0.21.0.wasm"
  ]
}
